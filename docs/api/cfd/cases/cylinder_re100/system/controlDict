FoamFile { version 2.0; format ascii; class dictionary; object controlDict; }
application     pimpleFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         160;
deltaT          0.005;
writeControl    adjustableRunTime;
writeInterval   25;
purgeWrite      3;
writeFormat     ascii;
writePrecision  8;
runTimeModifiable true;
adjustTimeStep  yes;
maxCo           5;
maxDeltaT       0.1;

functions
{
    forceCoeffs
    {
        type            forceCoeffs;
        libs            ("libforces.so");
        writeControl    timeStep;
        writeInterval   1;
        patches         (cylinder);
        rho             rhoInf;
        rhoInf          1;
        liftDir         (-0.087156 0.996195 0);
        dragDir         (0.996195 0.087156 0);
        CofR            (0 0 0);
        pitchAxis       (0 0 1);
        magUInf         1;
        lRef            1;        // D
        Aref            1;        // D * span = 1 * 1
    }
}
