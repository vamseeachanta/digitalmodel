{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aceengineer.com/schemas/plans/riser-contract-meta-v1.json",
  "title": "Issue 1602 planning-contract structural schema",
  "$defs": {
    "enumMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": ["string", "integer"]}
      }
    },
    "field": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {"type": "string", "minLength": 1},
        "disposition": {"type": "string"},
        "nullable": {"type": "boolean"},
        "const": {},
        "value": {},
        "enum": {"type": "array", "minItems": 1, "uniqueItems": true},
        "values": {"type": "array", "minItems": 1, "uniqueItems": true},
        "minimum": {"type": "number"},
        "maximum": {"type": "number"},
        "exclusive_minimum": {"type": "number"},
        "exclusive_maximum": {"type": "number"},
        "format": {"type": "string"},
        "identity_role": {"type": "string"},
        "min_items": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "entity": {
      "type": "object",
      "required": ["key", "fields"],
      "properties": {
        "key": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "fields": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/field"}},
        "constraints": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "releaseConfig": {
      "type": "object",
      "required": ["primary_key", "columns"],
      "properties": {
        "primary_key": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "unique": {"type": "array", "items": {"type": "array", "minItems": 1, "items": {"type": "string"}}},
        "columns": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/field"}},
        "conditional": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  },
  "oneOf": [
    {
      "type": "object",
      "required": ["schema_id", "schema_version", "additional_fields", "implicit_defaults", "decimal_type", "enums", "entities", "referential_integrity"],
      "properties": {
        "schema_id": {"const": "digitalmodel-riser-normalized-input"},
        "schema_version": {"type": "string"},
        "additional_fields": {"const": "reject"},
        "implicit_defaults": {"const": "reject"},
        "decimal_type": {"const": "canonical_decimal_v1"},
        "enums": {"$ref": "#/$defs/enumMap"},
        "entities": {"type": "object", "minProperties": 10, "additionalProperties": {"$ref": "#/$defs/entity"}},
        "referential_integrity": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["schema_id", "schema_version", "split", "additional_columns", "row_common", "enums", "configs", "foreign_keys"],
      "properties": {
        "schema_id": {"const": "digitalmodel-riser-hf-release"},
        "schema_version": {"type": "string"},
        "split": {"const": "train"},
        "additional_columns": {"const": "reject"},
        "row_common": {"type": "object", "required": ["release_id", "schema_version"], "additionalProperties": {"$ref": "#/$defs/field"}},
        "enums": {"$ref": "#/$defs/enumMap"},
        "configs": {"type": "object", "minProperties": 10, "additionalProperties": {"$ref": "#/$defs/releaseConfig"}},
        "foreign_keys": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["protocol_id", "protocol_version", "normalized_schema", "release_schema", "canonical_decimal_v1", "hash_framing_v1", "identity_construction_order", "coordinate_adapter_ENU_TRUE_NORTH_1_0_0", "host_attestation", "hf_publication", "website_withholding", "closeout_evidence_manifest", "contract_validation"],
      "properties": {
        "protocol_id": {"const": "digitalmodel-riser-analysis-protocol"},
        "protocol_version": {"type": "string"},
        "normalized_schema": {"type": "string"},
        "release_schema": {"type": "string"},
        "canonical_decimal_v1": {"type": "object"},
        "hash_framing_v1": {"type": "object"},
        "identity_construction_order": {"type": "array", "minItems": 20, "items": {"type": "string"}},
        "cross_platform_golden_vectors": {"type": "object"},
        "coordinate_adapter_ENU_TRUE_NORTH_1_0_0": {"type": "object"},
        "field_disposition_validation": {"type": "object"},
        "model_and_bundle": {"type": "object"},
        "transport_zip_store_v1": {"type": "object"},
        "host_attestation": {"type": "object"},
        "clean_room_attestation": {"type": "object"},
        "family_output_matrix": {"type": "object"},
        "engineering_oracles": {"type": "object"},
        "hf_publication": {"type": "object"},
        "website_withholding": {"type": "object"},
        "closeout_evidence_manifest": {"type": "object"},
        "contract_validation": {"type": "object"}
      },
      "additionalProperties": false
    }
  ]
}
