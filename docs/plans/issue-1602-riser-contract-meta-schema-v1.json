{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aceengineer.com/schemas/plans/riser-contract-meta-v1.json",
  "title": "Issue 1602 planning-contract structural schema",
  "$defs": {
    "nonEmptyObject": {"type": "object", "minProperties": 1},
    "enumMap": {
      "type": "object", "minProperties": 1,
      "additionalProperties": {
        "type": "array", "minItems": 1, "uniqueItems": true,
        "items": {"type": ["string", "integer"]}
      }
    },
    "field": {
      "type": "object", "required": ["type"],
      "properties": {
        "type": {"type": "string", "minLength": 1},
        "disposition": {"type": "string"}, "nullable": {"type": "boolean"},
        "const": {}, "value": {},
        "enum": {"type": "array", "minItems": 1, "uniqueItems": true},
        "values": {"type": "array", "minItems": 1, "uniqueItems": true},
        "minimum": {"type": "number"}, "maximum": {"type": "number"},
        "exclusive_minimum": {"type": "number"},
        "exclusive_maximum": {"type": "number"},
        "format": {"type": "string"}, "identity_role": {"type": "string"},
        "min_items": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "entity": {
      "type": "object", "required": ["key", "fields"],
      "properties": {
        "key": {"type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string"}},
        "fields": {"type": "object", "minProperties": 1,
          "additionalProperties": {"$ref": "#/$defs/field"}},
        "constraints": {"type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "releaseConfig": {
      "type": "object", "required": ["primary_key", "columns"],
      "properties": {
        "primary_key": {"type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string"}},
        "unique": {"type": "array", "items": {"type": "array",
          "minItems": 1, "items": {"type": "string"}}},
        "columns": {"type": "object", "minProperties": 1,
          "additionalProperties": {"$ref": "#/$defs/field"}},
        "conditional": {"type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  },
  "oneOf": [
    {
      "type": "object",
      "required": ["schema_id", "schema_version", "additional_fields",
        "implicit_defaults", "decimal_type", "enums", "entities",
        "referential_integrity"],
      "properties": {
        "schema_id": {"const": "digitalmodel-riser-normalized-input"},
        "schema_version": {"const": "1.0.0-draft.5"},
        "additional_fields": {"const": "reject"},
        "implicit_defaults": {"const": "reject"},
        "decimal_type": {"const": "canonical_decimal_v1"},
        "enums": {"$ref": "#/$defs/enumMap"},
        "entities": {"type": "object", "minProperties": 12,
          "additionalProperties": {"$ref": "#/$defs/entity"}},
        "referential_integrity": {"type": "array", "minItems": 12,
          "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["schema_id", "schema_version", "split",
        "additional_columns", "row_common", "enums", "configs",
        "foreign_keys", "cross_table_constraints"],
      "properties": {
        "schema_id": {"const": "digitalmodel-riser-hf-release"},
        "schema_version": {"const": "1.0.0-draft.5"},
        "split": {"const": "train"},
        "additional_columns": {"const": "reject"},
        "row_common": {"type": "object", "minProperties": 2,
          "required": ["release_id", "schema_version"],
          "additionalProperties": {"$ref": "#/$defs/field"}},
        "enums": {"$ref": "#/$defs/enumMap"},
        "configs": {"type": "object", "minProperties": 13,
          "maxProperties": 13,
          "additionalProperties": {"$ref": "#/$defs/releaseConfig"}},
        "foreign_keys": {"type": "array", "minItems": 15,
          "items": {"type": "string"}},
        "cross_table_constraints": {"type": "array", "minItems": 6,
          "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["protocol_id", "protocol_version", "normalized_schema",
        "release_schema", "canonical_decimal_v1", "hash_framing_v1",
        "identity_construction_order", "cross_platform_golden_vectors",
        "coordinate_adapter_ENU_TRUE_NORTH_1_0_0",
        "field_disposition_validation", "lineage_scope", "model_and_bundle",
        "transport_zip_store_v1", "host_attestation", "solver_semantic_success",
        "clean_room_attestation", "result_join_validation",
        "family_output_matrix", "engineering_oracles", "decoded_leak_scan",
        "hf_publication", "website_withholding",
        "closeout_evidence_manifest", "contract_validation"],
      "properties": {
        "protocol_id": {"const": "digitalmodel-riser-analysis-protocol"},
        "protocol_version": {"const": "1.0.0-draft.5"},
        "normalized_schema": {"type": "string", "minLength": 1},
        "release_schema": {"type": "string", "minLength": 1},
        "canonical_decimal_v1": {"$ref": "#/$defs/nonEmptyObject"},
        "hash_framing_v1": {"$ref": "#/$defs/nonEmptyObject"},
        "identity_construction_order": {"type": "array", "minItems": 30,
          "items": {"type": "string"}},
        "cross_platform_golden_vectors": {"$ref": "#/$defs/nonEmptyObject"},
        "coordinate_adapter_ENU_TRUE_NORTH_1_0_0": {"$ref": "#/$defs/nonEmptyObject"},
        "field_disposition_validation": {"$ref": "#/$defs/nonEmptyObject"},
        "lineage_scope": {"$ref": "#/$defs/nonEmptyObject"},
        "model_and_bundle": {"$ref": "#/$defs/nonEmptyObject"},
        "transport_zip_store_v1": {"$ref": "#/$defs/nonEmptyObject"},
        "host_attestation": {"$ref": "#/$defs/nonEmptyObject"},
        "solver_semantic_success": {"$ref": "#/$defs/nonEmptyObject"},
        "clean_room_attestation": {"$ref": "#/$defs/nonEmptyObject"},
        "result_join_validation": {"$ref": "#/$defs/nonEmptyObject"},
        "family_output_matrix": {"$ref": "#/$defs/nonEmptyObject"},
        "engineering_oracles": {"$ref": "#/$defs/nonEmptyObject"},
        "decoded_leak_scan": {"$ref": "#/$defs/nonEmptyObject"},
        "hf_publication": {"$ref": "#/$defs/nonEmptyObject"},
        "website_withholding": {"$ref": "#/$defs/nonEmptyObject"},
        "closeout_evidence_manifest": {"$ref": "#/$defs/nonEmptyObject"},
        "contract_validation": {"$ref": "#/$defs/nonEmptyObject"}
      },
      "additionalProperties": false
    }
  ]
}
