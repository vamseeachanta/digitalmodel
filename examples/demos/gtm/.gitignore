*.pyc
__pycache__/

# Results Store: the SQLite cache + WAL/SHM sidecars are rebuildable derived
# artifacts (regenerated from per-run cases.csv + manifest.json) — never tracked.
# Path-anchored so they do NOT swallow the tracked golden JSON fixtures.
results/parametric/**/*.db
results/parametric/**/*.db-wal
results/parametric/**/*.db-shm

# index.csv is a DERIVED view (like the .db): write_run upserts it, rebuild_db
# regenerates it from every per-run manifest.json. It accumulates client run rows,
# so it is NEVER tracked. The per-run cases.csv + manifest.json under baseline/
# remain the tracked source of truth.
results/parametric/demo_01/index.csv
results/parametric/demo_02/index.csv
results/parametric/demo_03/index.csv
results/parametric/demo_04/index.csv

# --- demo_01 ---
# Transient client run dirs under the Store are not tracked...
results/parametric/demo_01/*/
# ...but KEEP the committed Baseline reference run (cases.csv + manifest.json are source of truth).
!results/parametric/demo_01/baseline/
# Re-ignore any SQLite that lands inside the baseline dir (the db lives one level up anyway).
results/parametric/demo_01/baseline/*.db
results/parametric/demo_01/baseline/*.db-wal
results/parametric/demo_01/baseline/*.db-shm

