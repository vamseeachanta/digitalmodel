# The SQLite cache (+ WAL/SHM sidecars) is covered by the path-anchored globs above.
# Transient client run dirs under the Store are not tracked...
results/parametric/demo_03/*/
# ...but KEEP the committed Baseline reference run (its cases.csv + manifest.json are source of truth).
!results/parametric/demo_03/baseline/
# Re-ignore any SQLite that lands inside the baseline dir (the db lives one level up anyway).
results/parametric/demo_03/baseline/*.db
results/parametric/demo_03/baseline/*.db-wal
results/parametric/demo_03/baseline/*.db-shm

